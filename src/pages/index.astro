---
import { getCollection } from 'astro:content';
import AuthorCard from '../components/AuthorCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryList from '../components/CategoryList.astro';
import {
  getAllCategories,
  getCategoryCount,
  getFeaturedPosts,
  getVisiblePosts,
  slugify,
} from '../lib/blog';
import { HOME_HIGHLIGHTS, SITE_DESCRIPTION, SITE_TITLE, WRITING_WORKFLOW } from '../lib/site';

const posts = getVisiblePosts(await getCollection('blog'));
const featuredPosts = getFeaturedPosts(posts).slice(0, 2);
const latestPosts = posts.slice(0, 3);
const categoryCount = getCategoryCount(posts);
const categories = getAllCategories(posts).map((name) => ({
  name,
  count: categoryCount[name],
  slug: slugify(name),
}));
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="hero-panel">
    <div>
      <p class="eyebrow">Markdown 驱动的个人博客</p>
      <h1>用一套站点，同时管理写作、插图、公式和检索。</h1>
      <p class="hero-copy">
        这个网站基于 Astro 构建，支持 Markdown / MDX 写作、LaTeX 公式渲染、分类归档与全文检索，并默认鼓励使用更适合微信公众号同步的纯 Markdown 写作方式。
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/blog/">开始阅读</a>
        <a class="button button-secondary" href="/about/">关于我</a>
        <a class="button button-secondary" href="/search/">试试检索</a>
      </div>
    </div>
    <img
      class="hero-illustration"
      src="/illustrations/knowledge-orbit.svg"
      alt="一个围绕中心旋转的知识星系插图"
      loading="lazy"
    />
  </section>

  <section class="stats-grid">
    <article class="stats-card">
      <strong>{posts.length}</strong>
      <span>已发布文章</span>
    </article>
    <article class="stats-card">
      <strong>{categories.length}</strong>
      <span>主题分类</span>
    </article>
  </section>

  <section class="section-block split-layout">
    <AuthorCard title="这是一个适合长期写作的起点" />
    <div class="panel-stack">
      <article class="post-card">
        <div class="section-heading">
          <h2>写作节奏</h2>
          <a href="/guide/">完整规范</a>
        </div>
        <ol class="step-list">
          {WRITING_WORKFLOW.map((step) => <li>{step}</li>)}
        </ol>
      </article>
      <div class="feature-grid">
        {
          HOME_HIGHLIGHTS.map((item) => (
            <article class="feature-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {
    featuredPosts.length > 0 && (
      <section class="section-block">
        <div class="section-heading">
          <h2>精选文章</h2>
          <a href="/archives/">查看归档</a>
        </div>
        <div class="stack-grid">
          {featuredPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    )
  }

  <section class="section-block">
    <div class="section-heading">
      <h2>最近更新</h2>
      <a href="/blog/">查看全部</a>
    </div>
    <div class="stack-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <h2>分类导航</h2>
      <a href="/categories/">全部分类</a>
    </div>
    <CategoryList categories={categories} />
  </section>
</BaseLayout>
