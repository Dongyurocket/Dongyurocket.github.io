---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import { AUTHOR, NAV_LINKS, SITE_DESCRIPTION, SITE_TITLE } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
} = Astro.props as Props;

const pageTitle = title === SITE_TITLE ? title : `${title} | ${SITE_TITLE}`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const isActivePath = (href: string) =>
  href === '/' ? Astro.url.pathname === '/' : Astro.url.pathname.startsWith(href);
const ogImage = Astro.site ? new URL('/illustrations/knowledge-orbit.svg', Astro.site).toString() : '/illustrations/knowledge-orbit.svg';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f8fb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#101820" media="(prefers-color-scheme: dark)" />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <div class="reading-progress" aria-hidden="true">
      <span id="reading-progress-bar"></span>
    </div>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href="/">
          <span class="brand-mark">✦</span>
          <span>{SITE_TITLE}</span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          {
            NAV_LINKS.map((link) => (
              <a
                class:list={[
                  'nav-link',
                  isActivePath(link.href) && 'is-active',
                ]}
                href={link.href}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="shell page-shell" id="main-content">
      <slot />
    </main>

    <button class="back-to-top" type="button" aria-label="回到顶部">
      ↑
    </button>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <div>
          <p>{SITE_TITLE}</p>
          <p>{SITE_DESCRIPTION}</p>
        </div>
        <div>
          <p>{AUTHOR.name}</p>
          <p>
            <a href={AUTHOR.github} target="_blank" rel="noreferrer">GitHub</a>
          </p>
        </div>
      </div>
    </footer>

    <script>
      const progressBar = document.querySelector('#reading-progress-bar');
      const backToTop = document.querySelector('.back-to-top');

      const updateScrollUI = () => {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollable > 0 ? Math.min(window.scrollY / scrollable, 1) : 0;
        if (progressBar instanceof HTMLElement) {
          progressBar.style.transform = `scaleX(${progress})`;
        }
        if (backToTop instanceof HTMLButtonElement) {
          backToTop.classList.toggle('is-visible', window.scrollY > 520);
        }
      };

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      updateScrollUI();
      window.addEventListener('scroll', updateScrollUI, { passive: true });
      window.addEventListener('resize', updateScrollUI);
    </script>
  </body>
</html>
