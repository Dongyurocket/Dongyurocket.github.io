---
import type { CollectionEntry } from 'astro:content';
import { estimateReadingMinutes, formatDate, slugify } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props as Props;
const readingMinutes = estimateReadingMinutes(post.body);
const postUrl = `/blog/${post.id}/`;
---

<article
  class="post-card"
  data-post-card
  data-title={post.data.title}
  data-description={post.data.description}
  data-category={post.data.category}
  data-tags={post.data.tags.join('|')}
  data-date={post.data.pubDate.getTime()}
  data-reading-minutes={readingMinutes}
>
  <div class="post-card-meta">
    <a class="chip chip-link" href={`/categories/${slugify(post.data.category)}/`}>
      {post.data.category}
    </a>
    {post.data.featured && <span class="chip chip-warm">精选</span>}
    <time datetime={post.data.pubDate.toISOString()}>
      {formatDate(post.data.pubDate)}
    </time>
    <span>{readingMinutes} 分钟阅读</span>
  </div>
  <h2>
    <a href={postUrl}>{post.data.title}</a>
  </h2>
  <p>{post.data.description}</p>
  <a class="text-link" href={postUrl}>阅读全文</a>
  {
    post.data.tags.length > 0 && (
      <ul class="tag-list" aria-label="标签">
        {post.data.tags.map((tag) => <li class="chip">{tag}</li>)}
      </ul>
    )
  }
</article>
